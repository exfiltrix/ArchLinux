      "format-linked": "{ifname} (No IP) ´×ľ",
      "format-disconnected": " ÔÜá ",
      "format-alt": "{ifname}: {ipaddr}/{cidr}"
    },
    "hyprland/language": {
    "format": "{short}",
    "rewrite": {
