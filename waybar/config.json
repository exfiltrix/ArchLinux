      "on-click": "activate",
      "format-icons": {
        "active": "´äĹ "
      },
      "sort-by-number": true,
      "persistent-workspaces": {
        "*": 4,
        "HDMI-A-1": 3
      }
    },
    "clock": {
      "format": "{:%H:%M}",
      "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
      "format-alt": "{:%Y-%m-%d}"
    },
    "cpu": {
      "format": "´őŤ {usage}%",
      "tooltip": false
    },
    "memory": {
      "format": "´öŞ {}%"
    },
    "temperature": {
      "critical-threshold": 80,
