{
  "position": "top",
    "margin-top" : 5,
    "margin-left": 10,
    "margin-right": 10,
    "height" : 30,
    "modules-left": [
      "custom/arch",
      "hyprland/workspaces"
    ],
    "modules-center": [
      "hyprland/window"
    ],
    "modules-right": [
    "pulseaudio",
    "backlight",
    "cpu",
    "memory",
    "temperature"1
    "battery",
    "network",
    "clock",
    "custom/exit"
    ],
       "hyprland/window": {
      "format": "{}",
      "max-length": 35,
      "rewrite": {
        "": "Hyprland"
      },
      "separate-outputs": true
    },
    "hyprland/workspaces": {
      "format": "{id} {windows} ",
      "format-window-separator": " ",
      "window-rewrite-default": "ΎΕρ",
      "window-rewrite": {
        "title<.*youtube.*>": "≤░ΩΔ",
        "class<firefox>": "≤░Ι╣",
        "class<google-chrome>": "ΎΚρ",
        "class<chromium>": "ΎΚρ",
        "class<telegram-desktop>": "ΎΜΗ",
        "class<discord>": "≤░βψ",
        "class<code>": "≤░ρη",
        "class<kitty>": "ΎΤΚ",
        "class<alacritty>": "ΎΤΚ",
        "class<nautilus>": "≤░ΚΜ",
        "class<thunar>": "≤░ΚΜ",
        "class<spotify>": "≤░ΥΘ",
        "class<steam>": "ΎΗ╢",
        "class<obsidian>": "≤░ιχ"
      },
      "on-click": "activate",
      "sort-by-number": true,
      "persistent-workspaces": {
        "*": 9,
        "HDMI-A-1": 3
      }
    },
    "clock": {
      "format": "{:%H:%M}",
      "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
      "format-alt": "{:%Y-%m-%d}"
    },
    "cpu": {
      "format": "ΎΜδ {usage}%",
      "tooltip": false
    },
    "memory": {
      "format": "ΎΦ╕ {}%"
    },
    "temperature": {
      "critical-threshold": 80,
      "format": "{icon} {temperatureC}┬░C",
      "format-icons": ["Ύζτ", "ΎΜΚ", "Ύζσ"]
    },
    "battery": {
      "states": {
        "warning": 30,
        "critical": 15
      },
      "format": "{icon}  {capacity}%",
      "format-full": "{icon}  {capacity}%",
      "format-charging": "ΎΩπ  {capacity}%",
      "format-plugged": "ΎΘο  {capacity}%",
      "format-alt": "{time} {icon}",
      "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"]
    },
    "network": {
      "format-wifi": "ΎΘτ  {signalStrength}%",
      "format-ethernet": "{cidr} ΎηΨ",
      "tooltip-format": "{ifname} via {gwaddr} ΎηΨ",
      "format-linked": "{ifname} (No IP) ΎηΨ",
      "format-disconnected": " έγι ",
      "format-alt": "{ifname}: {ipaddr}/{cidr}"
    },
    "hyprland/language": {
    "format": "{short}",
    "rewrite": {
        "Russian": "RU",
        "English (US)": "ENG"
    }
    },
    "pulseaudio": {
      "format": "{icon} {volume}%",
      "format-bluetooth": "{volume}% {icon}ΎΛΦ {format_source}",
      "format-bluetooth-muted": "Ύγσ {icon}ΎΛΦ {format_source}",
      "format-muted": "Ύγσ {format_source}",
      "format-icons": {
        "headphone": "ΎΑξ",
        "hands-free": "ΎΨΡ",
        "headset": "ΎΨΡ",
        "phone": "ΎΓΧ",
        "portable": "ΎΓΧ",
        "car": "ΎΗ╣",
        "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
      },
      "on-click": "pavucontrol"
    },
    "backlight": {
      "device": "intel_backlight",
      "format": "{icon} {percent}%",
      "format-icons": ["ΎΗΖ", "ΎΕΣ"]
    },
    "custom/exit": {
        "format": "ΎΑΣ",
        "on-click": "wlogout",
        "tooltip": false
    },
}
